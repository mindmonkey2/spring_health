// EXPECTED ACCESS MATRIX:
// ADMIN (owner role):
//   ✓ Read /members/{anyId}
//   ✓ Read /payments/{anyId}
//   ✓ Read /attendance/{anyId}
//   ✓ Read /users/{ownUid}
//
// MEMBER (phone OTP user — NO users collection document):
//   ✓ Read /members/{ownMemberId}
//   ✓ Read /attendance/{ownAttendanceId}
//   ✓ Read /workouts/{ownWorkoutId}
//   ✗ Read /members/{otherMemberId}  ← must DENY
//
// CRITICAL: isMember() always returns false for phone OTP users.
//           Member-side rules use isSignedIn() + isOwnRecord() instead.
//           Role values are Title Case: 'Owner','Receptionist','Trainer','Member'

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // HELPER FUNCTIONS
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Owner';
    }

    function isReceptionist() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Receptionist';
    }

    function isTrainer() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Trainer';
    }

    function isStaff() {
      return isOwner() || isReceptionist();
    }

    // NOTE: isMember() is intentionally NOT used for member-side collection rules.
    // Phone OTP members have no users/{uid} document, so this always returns false
    // for them. Kept only for future use if member docs are added to users collection.
    function isMember() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Member';
    }

    function isOwnDocument(uid) {
      return request.auth.uid == uid;
    }

    // Checks uid, memberId, or user_id fields — covers all member doc patterns
    function isOwnRecord(docData) {
      return ('uid' in docData && docData.uid == request.auth.uid) ||
             ('memberId' in docData && docData.memberId == request.auth.uid) ||
             ('user_id' in docData && docData.user_id == request.auth.uid);
    }

    // -------------------------------------------------------------------------
    // USERS COLLECTION
    // -------------------------------------------------------------------------
    // - Any authenticated user can read their own document
    // - Owner can read/write all user documents
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwnDocument(userId) || isOwner());
      allow write: if isOwner();
    }

    // -------------------------------------------------------------------------
    // MEMBERS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner/Receptionist: full read/write
    // - Trainer: read only (their assigned members)
    // - Member (phone OTP): read own doc by uid field or doc ID
    // - Member: update only photoUrl, uid, fcmToken fields
    match /members/{memberId} {
      allow read: if isStaff() ||
                     (isTrainer() && 'trainerId' in resource.data &&
                      resource.data.trainerId == request.auth.uid) ||
                     (isSignedIn() && (
                       isOwnDocument(memberId) ||
                       ('uid' in resource.data && resource.data.uid == request.auth.uid) ||
                       ('user_id' in resource.data && resource.data.user_id == request.auth.uid)
                     ));
      allow create: if isStaff();
      allow update: if isStaff() ||
                       (isSignedIn() && (
                         isOwnDocument(memberId) ||
                         ('uid' in resource.data && resource.data.uid == request.auth.uid) ||
                         ('user_id' in resource.data && resource.data.user_id == request.auth.uid)
                       ) &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['photoUrl', 'uid', 'fcmToken']));
      allow delete: if isStaff();
    }

    // -------------------------------------------------------------------------
    // ATTENDANCE COLLECTION
    // -------------------------------------------------------------------------
    // - Owner/Receptionist: full read/write
    // - Trainer: read only
    // - Member: read own records, create new check-in
    match /attendance/{attendanceId} {
      allow read: if isStaff() || isTrainer() ||
                     (isSignedIn() && isOwnRecord(resource.data));
      allow create: if isStaff() || (isSignedIn() && isOwnRecord(request.resource.data));
      allow update, delete: if isStaff();
    }

    // -------------------------------------------------------------------------
    // PAYMENTS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner/Receptionist: full read/write
    // - Member: read own payment records only
    match /payments/{paymentId} {
      allow read: if isStaff() || (isSignedIn() && isOwnRecord(resource.data));
      allow write: if isStaff();
    }

    // -------------------------------------------------------------------------
    // WORKOUTS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner/Receptionist/Trainer: read only
    // - Member: full read/write on own documents
    match /workouts/{workoutId} {
      allow read: if isStaff() || isTrainer() ||
                     (isSignedIn() && isOwnRecord(resource.data));
      allow create: if isSignedIn() && isOwnRecord(request.resource.data);
      allow update, delete: if isSignedIn() && isOwnRecord(resource.data);
    }

    // -------------------------------------------------------------------------
    // GAMIFICATION COLLECTION
    // -------------------------------------------------------------------------
    // - Owner: full read/write
    // - Receptionist/Trainer: read only
    // - Member: read/write own document
    match /gamification/{gamificationId} {
      allow read: if isOwner() || isReceptionist() || isTrainer() ||
                     (isSignedIn() && isOwnRecord(resource.data));
      allow create: if isOwner() || (isSignedIn() && isOwnRecord(request.resource.data));
      allow update, delete: if isOwner() || (isSignedIn() && isOwnRecord(resource.data));
    }

    // -------------------------------------------------------------------------
    // GAMIFICATION EVENTS — Studio fires, member app reads + marks processed
    // Both collection name variants kept for compatibility
    // -------------------------------------------------------------------------
    match /gamification_events/{eventId} {
      allow read: if isStaff() ||
                     (isSignedIn() && 'memberId' in resource.data &&
                      resource.data.memberId == request.auth.uid);
      allow create: if isStaff();
      allow update: if isStaff() ||
                       (isSignedIn() && 'memberId' in resource.data &&
                        resource.data.memberId == request.auth.uid &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['processed']));
    }

    match /gamificationEvents/{eventId} {
      allow read: if isStaff() ||
                     (isSignedIn() && 'memberId' in resource.data &&
                      resource.data.memberId == request.auth.uid);
      allow create: if isStaff();
      allow update: if isStaff() ||
                       (isSignedIn() && 'memberId' in resource.data &&
                        resource.data.memberId == request.auth.uid &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['processed']));
    }

    // -------------------------------------------------------------------------
    // WEEKLY WARS COLLECTION
    // -------------------------------------------------------------------------
    match /weekly_wars/{warId} {
      allow read: if isOwner() || isReceptionist() || isSignedIn();
      allow create: if isOwner() || isReceptionist();
      allow update, delete: if isOwner() || isReceptionist();
    }

    match /notificationsQueue/{queueId} {
      allow read: if isOwner();
      allow create: if isStaff();
    }

    // -------------------------------------------------------------------------
    // PERSONAL_BESTS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner/Trainer: read only
    // - Member: read/write own documents
    match /personal_bests/{pbId} {
      allow read: if isOwner() || isTrainer() ||
                     (isSignedIn() && isOwnRecord(resource.data));
      allow create: if isSignedIn() && isOwnRecord(request.resource.data);
      allow update, delete: if isSignedIn() && isOwnRecord(resource.data);
    }

    // -------------------------------------------------------------------------
    // ANNOUNCEMENTS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner/Receptionist: full create/delete
    // - Any signed-in user: read
    // - Member: can update readBy array only (mark as read)
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, delete: if isStaff();
      allow update: if isStaff() ||
                       (isSignedIn() &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['readBy']));
    }

    // -------------------------------------------------------------------------
    // HEALTH & AI METRICS (Phase 1–3 AI Foundation)
    // -------------------------------------------------------------------------
    // Note: memberId here is the Firebase Auth UID (set during health profile creation)
    match /healthProfiles/{memberId} {
      allow read: if isOwner() || isTrainer() ||
                     (isSignedIn() && request.auth.uid == memberId);
      allow write: if isSignedIn() && request.auth.uid == memberId;
    }

    match /aiPlans/{memberId} {
      allow read: if isOwner() || isTrainer() ||
                     (isSignedIn() && request.auth.uid == memberId);
      allow write: if isSignedIn() && request.auth.uid == memberId;
      match /current/{docId} {
        allow read: if isOwner() || isTrainer() ||
                       (isSignedIn() && request.auth.uid == memberId);
        allow write: if isSignedIn() && request.auth.uid == memberId;
      }
    }

    match /wearableSnapshots/{memberId} {
      allow read: if isOwner() || isTrainer() ||
                     (isSignedIn() && request.auth.uid == memberId);
      allow write: if isSignedIn() && request.auth.uid == memberId;
      match /daily/{date} {
        allow read: if isOwner() || isTrainer() ||
                       (isSignedIn() && request.auth.uid == memberId);
        allow write: if isSignedIn() && request.auth.uid == memberId;
      }
    }

    match /bodyMetricsLogs/{memberId} {
      allow read: if isOwner() || isTrainer() ||
                     (isSignedIn() && request.auth.uid == memberId);
      allow write: if isSignedIn() && request.auth.uid == memberId;
      match /logs/{logId} {
        allow read: if isOwner() || isTrainer() ||
                       (isSignedIn() && request.auth.uid == memberId);
        allow write: if isSignedIn() && request.auth.uid == memberId;
      }
    }

    match /fitnessTests/{memberId} {
      allow read: if isOwner() || isTrainer() ||
                     (isSignedIn() && request.auth.uid == memberId);
      allow write: if isSignedIn() && request.auth.uid == memberId;
      match /tests/{testId} {
        allow read: if isOwner() || isTrainer() ||
                       (isSignedIn() && request.auth.uid == memberId);
        allow write: if isSignedIn() && request.auth.uid == memberId;
      }
    }

    match /bodyMetrics/{docId} {
      allow read: if isOwner() || isTrainer() ||
                     (isSignedIn() && isOwnRecord(resource.data));
      allow create: if isSignedIn() && isOwnRecord(request.resource.data);
      allow update, delete: if isSignedIn() && isOwnRecord(resource.data);
    }

    // -------------------------------------------------------------------------
    // NOTIFICATIONS & NOTIFICATION HISTORY COLLECTIONS
    // -------------------------------------------------------------------------
    // - Owner/Receptionist: full read/write
    // - Member: read own notifications, manage own items subcollection
    match /notifications/{notificationId} {
      allow read: if isStaff() ||
                     (isSignedIn() && (isOwnDocument(notificationId) ||
                      isOwnRecord(resource.data)));
      allow write: if isStaff();

      match /items/{itemId} {
        allow read, write: if isStaff() ||
                              (isSignedIn() && isOwnDocument(notificationId));
      }
    }

    match /notificationHistory/{historyId} {
      allow read: if isStaff() || (isSignedIn() && isOwnRecord(resource.data));
      allow write: if isStaff();
    }

    // -------------------------------------------------------------------------
    // TRAINERS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner: full read/write
    // - Receptionist/Member/Trainer: read only
    // - Trainer: can update own document
    match /trainers/{trainerId} {
      allow read: if isSignedIn();
      allow create, delete: if isOwner();
      allow update: if isOwner() || (isTrainer() && isOwnDocument(trainerId));
    }

    // -------------------------------------------------------------------------
    // TRAINERFEEDBACK COLLECTION
    // -------------------------------------------------------------------------
    // - Any signed-in user: create (submit feedback)
    // - Trainer: read and update own feedback
    // - Owner: full read/write
    match /trainerFeedback/{feedbackId} {
      allow read: if isOwner() ||
                     (isTrainer() && 'trainerId' in resource.data &&
                      resource.data.trainerId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isOwner() ||
                       (isTrainer() && 'trainerId' in resource.data &&
                        resource.data.trainerId == request.auth.uid);
      allow delete: if isOwner();
    }

    // -------------------------------------------------------------------------
    // DIETPLANS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner/Trainer: full read/write
    // - Member: read only (global), read/write own AI diet plans
    match /dietPlans/{memberId} {
      allow read: if isSignedIn();
      allow write: if isOwner() || isTrainer() ||
                      (isSignedIn() && request.auth.uid == memberId);
      match /current/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == memberId;
      }
    }

    // -------------------------------------------------------------------------
    // EXPENSES COLLECTION
    // -------------------------------------------------------------------------
    // - Owner: full read/write
    // - Receptionist: read only
    // - Member/Trainer: no access
    match /expenses/{expenseId} {
      allow read: if isOwner() || isReceptionist();
      allow write: if isOwner();
    }

    // -------------------------------------------------------------------------
    // SESSIONS & FITNESSDATA COLLECTIONS
    // -------------------------------------------------------------------------
    // - Owner/Trainer: read only
    // - Member: read/write own documents
    match /sessions/{sessionId} {
      allow read: if isOwner() || isTrainer() ||
                     (isSignedIn() && isOwnRecord(resource.data));
      allow create: if isSignedIn() && isOwnRecord(request.resource.data);
      allow update, delete: if isSignedIn() && isOwnRecord(resource.data);
    }

    match /fitnessData/{dataId} {
      allow read: if isOwner() || isTrainer() ||
                     (isSignedIn() && isOwnRecord(resource.data));
      allow create: if isSignedIn() && isOwnRecord(request.resource.data);
      allow update, delete: if isSignedIn() && isOwnRecord(resource.data);
    }

    // -------------------------------------------------------------------------
    // FCMTOKENS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner: read all
    // - Any authenticated user: write own token
    match /fcmTokens/{tokenId} {
      allow read: if isOwner();
      allow write: if isSignedIn() && (
        isOwnDocument(tokenId) ||
        ('uid' in request.resource.data && request.resource.data.uid == request.auth.uid) ||
        ('memberId' in request.resource.data && request.resource.data.memberId == request.auth.uid)
      );
    }

    // -------------------------------------------------------------------------
    // CHALLENGES & CHALLENGEENTRIES COLLECTIONS
    // -------------------------------------------------------------------------
    // - Owner: full read/write
    // - Any signed-in user: read challenges
    // - Member: read/write own entries
    match /challenges/{challengeId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    match /challengeEntries/{entryId} {
      allow read: if isOwner() || isReceptionist() ||
                     (isSignedIn() && isOwnRecord(resource.data));
      allow create: if isOwner() || (isSignedIn() && isOwnRecord(request.resource.data));
      allow update, delete: if isOwner() || (isSignedIn() && isOwnRecord(resource.data));
    }

    // -------------------------------------------------------------------------
    // REMINDER_LOGS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner/Receptionist: full read/write
    match /reminder_logs/{logId} {
      allow read, write: if isStaff();
    }

  }
}
