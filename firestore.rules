// EXPECTED ACCESS MATRIX:
// ADMIN (owner role):
//   ✓ Read /members/{anyId}
//   ✓ Read /payments/{anyId}
//   ✓ Read /attendance/{anyId}
//   ✓ Read /users/{ownUid}
//
// MEMBER (member role):
//   ✓ Read /members/{ownMemberId}
//   ✓ Read /attendance/{ownAttendanceId}
//   ✓ Read /workouts/{ownWorkoutId}
//   ✗ Read /members/{otherMemberId}  ← must DENY

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // HELPER FUNCTIONS
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    function isReceptionist() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'receptionist';
    }

    function isTrainer() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer';
    }

    function isStaff() {
      return isOwner() || isReceptionist();
    }

    function isMember() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'member';
    }

    function isOwnDocument(uid) {
      return request.auth.uid == uid;
    }

    function isOwnRecord(docData) {
      return ('uid' in docData && docData.uid == request.auth.uid) ||
             ('memberId' in docData && docData.memberId == request.auth.uid) ||
             ('user_id' in docData && docData.user_id == request.auth.uid);
    }

    // -------------------------------------------------------------------------
    // USERS COLLECTION
    // -------------------------------------------------------------------------
    // - Any authenticated user can read their own document
    // - Owner can read/write all user documents
    // - No one else can write user documents
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwnDocument(userId) || isOwner());
      allow write: if isOwner();
    }

    // -------------------------------------------------------------------------
    // MEMBERS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner: full read/write
    // - Receptionist: full read/write
    // - Trainer: read only (their assigned members)
    // - Member: can only read their OWN document
    //   (where resource.data.uid == request.auth.uid OR document ID == request.auth.uid)
    // - Member: can update only their photoUrl field
    match /members/{memberId} {
      allow read: if isStaff() ||
                     (isTrainer() && 'trainerId' in resource.data && resource.data.trainerId == request.auth.uid) ||
                     (isMember() && (isOwnDocument(memberId) || ('uid' in resource.data && resource.data.uid == request.auth.uid) || ('user_id' in resource.data && resource.data.user_id == request.auth.uid)));
      allow create: if isStaff();
      allow update: if isStaff() ||
                       (isMember() && (isOwnDocument(memberId) || ('uid' in resource.data && resource.data.uid == request.auth.uid) || ('user_id' in resource.data && resource.data.user_id == request.auth.uid)) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photoUrl']));
      allow delete: if isStaff();
    }

    // -------------------------------------------------------------------------
    // ATTENDANCE COLLECTION
    // -------------------------------------------------------------------------
    // - Owner: full read/write
    // - Receptionist: full read/write
    // - Trainer: read only
    // - Member: can read own records, can create new check-in
    match /attendance/{attendanceId} {
      allow read: if isStaff() || isTrainer() || (isMember() && isOwnRecord(resource.data));
      allow create: if isStaff() || (isMember() && isOwnRecord(request.resource.data));
      allow update, delete: if isStaff();
    }

    // -------------------------------------------------------------------------
    // PAYMENTS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner: full read/write
    // - Receptionist: full read/write
    // - Trainer: no access
    // - Member: can read own payment records only
    match /payments/{paymentId} {
      allow read: if isStaff() || (isMember() && isOwnRecord(resource.data));
      allow write: if isStaff();
    }

    // -------------------------------------------------------------------------
    // WORKOUTS COLLECTION
    // -------------------------------------------------------------------------
    // - Member: full read/write on own documents only
    // - Owner/Receptionist: read only
    match /workouts/{workoutId} {
      allow read: if isStaff() || (isMember() && isOwnRecord(resource.data));
      allow create: if isMember() && isOwnRecord(request.resource.data);
      allow update, delete: if isMember() && isOwnRecord(resource.data);
    }

    // -------------------------------------------------------------------------
    // GAMIFICATION COLLECTION
    // -------------------------------------------------------------------------
    // - Member: read/write own document only
    // - Owner: full read/write
    // - Receptionist: read only
    match /gamification/{gamificationId} {
      allow read: if isOwner() || isReceptionist() || (isMember() && isOwnRecord(resource.data));
      allow create: if isOwner() || (isMember() && isOwnRecord(request.resource.data));
      allow update, delete: if isOwner() || (isMember() && isOwnRecord(resource.data));
    }

    match /gamification_events/{eventId} {
      allow read: if isStaff();
      allow create: if isStaff();
    }

    match /gamificationEvents/{eventId} {
      allow read: if isStaff();
      allow create: if isStaff();
    }

    match /weekly_wars/{warId} {
      allow read: if isOwner() || isReceptionist() || isMember();
      allow create: if isOwner() || isReceptionist();
      allow update, delete: if isOwner() || isReceptionist();
    }

    match /notificationsQueue/{queueId} {
      allow read: if isOwner();
      allow create: if isStaff();
    }

    // -------------------------------------------------------------------------
    // PERSONAL_BESTS COLLECTION
    // -------------------------------------------------------------------------
    // - Member: read/write own documents only
    // - Owner: read only
    match /personal_bests/{pbId} {
      allow read: if isOwner() || (isMember() && isOwnRecord(resource.data));
      allow create: if isMember() && isOwnRecord(request.resource.data);
      allow update, delete: if isMember() && isOwnRecord(resource.data);
    }

    // -------------------------------------------------------------------------
    // ANNOUNCEMENTS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner/Receptionist: full read/write
    // - Member/Trainer: read only
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // -------------------------------------------------------------------------
    // HEALTH & AI METRICS (Phase 1 AI Foundation)
    // -------------------------------------------------------------------------
    // Health profiles — member reads/writes own only
    match /healthProfiles/{memberId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == memberId;
    }

    // AI Plans
    match /aiPlans/{memberId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == memberId;
      match /current/{docId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == memberId;
      }
    }

    match /wearableSnapshots/{memberId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == memberId;
      match /daily/{date} {
        allow read, write: if request.auth != null
                           && request.auth.uid == memberId;
      }
    }

    // Body metrics logs
    match /bodyMetricsLogs/{memberId}/logs/{logId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == memberId;
    }

    // Fitness tests
    match /fitnessTests/{memberId}/tests/{testId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == memberId;
    }

    // -------------------------------------------------------------------------
    // NOTIFICATIONS & NOTIFICATION HISTORY COLLECTIONS
    // -------------------------------------------------------------------------
    // - Owner: full read/write
    // - Member: read only own notifications (and manage own local subcollection)
    // - Receptionist: read/write
    match /notifications/{notificationId} {
      allow read: if isStaff() || (isMember() && (isOwnDocument(notificationId) || isOwnRecord(resource.data)));
      allow write: if isStaff();

      // Allow subcollections for notifications/{uid}/items/{notifId} per AGENTS.md
      match /items/{itemId} {
        allow read, write: if isStaff() || (isMember() && isOwnDocument(notificationId));
      }
    }
    match /notificationHistory/{historyId} {
      allow read: if isStaff() || (isMember() && isOwnRecord(resource.data));
      allow write: if isStaff();
    }

    // -------------------------------------------------------------------------
    // TRAINERS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner: full read/write
    // - Receptionist: read only
    // - Trainer: can read/update own document only
    // - Member: read only
    match /trainers/{trainerId} {
      allow read: if isSignedIn();
      allow create, delete: if isOwner();
      allow update: if isOwner() || (isTrainer() && isOwnDocument(trainerId));
    }

    // -------------------------------------------------------------------------
    // TRAINERFEEDBACK COLLECTION
    // -------------------------------------------------------------------------
    // - Member: create only (submit feedback)
    // - Trainer: read own feedback, write replies
    // - Owner: full read/write
    match /trainerFeedback/{feedbackId} {
      allow read: if isOwner() || (isTrainer() && 'trainerId' in resource.data && resource.data.trainerId == request.auth.uid);
      allow create: if isOwner() || isMember();
      allow update: if isOwner() || (isTrainer() && 'trainerId' in resource.data && resource.data.trainerId == request.auth.uid);
      allow delete: if isOwner();
    }

    // -------------------------------------------------------------------------
    // DIETPLANS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner/Trainer: full read/write
    // - Member: read only, full access to own AI diet plans
    match /dietPlans/{memberId} {
      allow read: if isSignedIn();
      allow write: if isOwner() || isTrainer() || (request.auth != null && request.auth.uid == memberId);
      match /current/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == memberId;
      }
    }

    // -------------------------------------------------------------------------
    // EXPENSES COLLECTION
    // -------------------------------------------------------------------------
    // - Owner: full read/write
    // - Receptionist: read only
    // - Member/Trainer: no access
    match /expenses/{expenseId} {
      allow read: if isOwner() || isReceptionist();
      allow write: if isOwner();
    }

    // -------------------------------------------------------------------------
    // SESSIONS & FITNESSDATA COLLECTIONS
    // -------------------------------------------------------------------------
    // - Member: read/write own documents only
    // - Owner: read only
    match /sessions/{sessionId} {
      allow read: if isOwner() || (isMember() && isOwnRecord(resource.data));
      allow create: if isMember() && isOwnRecord(request.resource.data);
      allow update, delete: if isMember() && isOwnRecord(resource.data);
    }
    match /fitnessData/{dataId} {
      allow read: if isOwner() || (isMember() && isOwnRecord(resource.data));
      allow create: if isMember() && isOwnRecord(request.resource.data);
      allow update, delete: if isMember() && isOwnRecord(resource.data);
    }

    // -------------------------------------------------------------------------
    // FCMTOKENS COLLECTION
    // -------------------------------------------------------------------------
    // - Any authenticated user: write own token
    // - Owner: read all
    match /fcmTokens/{tokenId} {
      allow read: if isOwner();
      allow write: if isSignedIn() && (isOwnDocument(tokenId) || ('uid' in request.resource.data && request.resource.data.uid == request.auth.uid) || ('memberId' in request.resource.data && request.resource.data.memberId == request.auth.uid));
    }

    // -------------------------------------------------------------------------
    // CHALLENGES & CHALLENGEENTRIES COLLECTIONS
    // -------------------------------------------------------------------------
    // - Owner: full read/write
    // - Member: read challenges, read/write own entries
    match /challenges/{challengeId} {
      allow read: if isOwner() || isMember();
      allow write: if isOwner();
    }
    match /challengeEntries/{entryId} {
      allow read: if isOwner() || (isMember() && isOwnRecord(resource.data));
      allow create: if isOwner() || (isMember() && isOwnRecord(request.resource.data));
      allow update, delete: if isOwner() || (isMember() && isOwnRecord(resource.data));
    }

    // -------------------------------------------------------------------------
    // REMINDER_LOGS COLLECTION
    // -------------------------------------------------------------------------
    // - Owner/Receptionist: full read/write
    // - Others: no access
    match /reminder_logs/{logId} {
      allow read, write: if isStaff();
    }
  }
}
