rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Owner';
    }
    
    function isReceptionist() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Receptionist';
    }

    function isTrainer() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Trainer';
    }
    
    function getUserBranch() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branch;
    }
    
    function isSameBranch(branch) {
      return isReceptionist() && getUserBranch() == branch;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isOwner();
    }
    
    // Members collection
    match /members/{memberId} {
      allow read: if isAuthenticated() && (
        isOwner() || 
        (isReceptionist() && isSameBranch(resource.data.branch))
      );
      
      allow create: if isAuthenticated() && (
        isOwner() || 
        (isReceptionist() && isSameBranch(request.resource.data.branch))
      );
      
      allow update: if isAuthenticated() && (
        isOwner() || 
        (isReceptionist() && isSameBranch(resource.data.branch))
      );
      
      allow delete: if isOwner();
    }
    
    // Attendance collection
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && (
        isOwner() || 
        (isReceptionist() && isSameBranch(resource.data.branch))
      );
      
      allow create: if isAuthenticated();
      allow update, delete: if isOwner();
    }
    
    // Payments collection
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        isOwner() || 
        (isReceptionist() && isSameBranch(resource.data.branch))
      );
      
      allow create: if isAuthenticated();
      allow update, delete: if isOwner();
    }

    // Sessions collection
    match /sessions/{sessionId} {
      allow create, update: if isTrainer() || isOwner();
      allow read: if isTrainer() || isOwner()
        || (isSignedIn()
            && resource.data.memberAuthUid == request.auth.uid);
      allow delete: if isOwner();
    }

    match /trainerTeamBattles/{battleId} {
      allow create: if isTrainer();
      allow read, update: if isOwner()
        || (isTrainer()
            && resource.data.organizerTrainerId == request.auth.uid);
      allow delete: if isOwner();
    }
  }
}
